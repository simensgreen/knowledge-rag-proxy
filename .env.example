# Copy to .env and edit paths for your host.
# See AGENTS.md for full variable reference.

# Required
GRIM_BEARER=your-secret-token
GRIM_DOCUMENTS_DIR=/absolute/path/to/your/documents

# Paths (optional)
# GRIM_TMP_DIR=/absolute/path/to/tmp
# GRIM_SURREAL_URL=surrealkv:///absolute/path/to/surreal

# Embedding provider (Phase 2)
# GRIM_EMBEDDING_PROVIDER=openai_compat
# GRIM_EMBEDDING_BASE_URL=https://...
# GRIM_EMBEDDING_TOKEN=...
# GRIM_EMBEDDING_MODEL=text-embedding-3-small
# GRIM_EMBEDDING_DIMENSIONS=1536

# OCR provider (Phase 2)
# GRIM_OCR_PROVIDER=openai_compat
# GRIM_OCR_BASE_URL=https://...
# GRIM_OCR_TOKEN=...
# GRIM_OCR_MODEL=...

# Search (optional)
# GRIM_SEARCH_DEFAULT_RESULTS=5
# GRIM_SEARCH_MAX_RESULTS=20

# Watcher (optional)
# GRIM_WATCH_DEBOUNCE=10
# GRIM_WATCH_DISABLED=0

# API docs (optional)
# GRIM_DOCS=0
# GRIM_LOG_LEVEL=INFO
