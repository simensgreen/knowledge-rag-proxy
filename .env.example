# Copy to .env and edit paths for your host.
# See AGENTS.md for full variable reference.

# Required
KRP_BEARER=your-secret-token
# Folder to index, watch, upload to, and download from. Must already exist.
# Keep it OUT of macOS TCC-protected dirs (~/Documents, ~/Desktop, ~/Downloads)
# unless the server process has Full Disk Access.
KRP_DOCUMENTS_DIR=/absolute/path/to/your/documents

# Internal base for the embedded knowledge-rag library. It eagerly creates
# {KNOWLEDGE_RAG_DIR}/{documents,data,models_cache} on import; this base is
# throwaway (all real paths are overridden). When unset, defaults to
# {KRP_TMP_DIR or system temp}/knowledge-rag-proxy/base. Usually leave both unset.
# KNOWLEDGE_RAG_DIR=/absolute/path/to/library-base

# Temp dir for in-progress uploads and the library base above. Optional;
# unset uses the system temp (tempfile.gettempdir()). Set it to keep temp
# work off a specific volume (e.g. away from a synced/tmpfs mount).
# KRP_TMP_DIR=/absolute/path/to/tmp

# Storage for ChromaDB + metadata and the embedding-model cache.
# Optional; default to a per-user app-data dir (platformdirs):
#   macOS   ~/Library/Application Support/knowledge-rag-proxy/{db,models_cache}
#   Linux   ~/.local/share/knowledge-rag-proxy/{db,models_cache}
#   Windows %LOCALAPPDATA%\knowledge-rag-proxy\{db,models_cache}
# KRP_DATA_DIR=/path/to/db
# KRP_MODELS_CACHE_DIR=/path/to/models_cache

# Models (optional)
# KRP_EMBEDDING_MODEL=BAAI/bge-m3
# KRP_RERANKER_ENABLED=true
# KRP_RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# Search (optional)
# KRP_SEARCH_DEFAULT_RESULTS=5
# KRP_SEARCH_MAX_RESULTS=20
# KRP_COLLECTION_NAME=knowledge_base

# Watcher (optional)
# KRP_WATCH_DEBOUNCE=10
# KRP_WATCH_DISABLED=0

# API docs (optional)
# KRP_DOCS=0
