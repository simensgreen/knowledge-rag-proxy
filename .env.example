# Copy to .env and edit paths for your host.
# See AGENTS.md for full variable reference.

# Required
GRIM_DOCUMENTS_DIR=/absolute/path/to/your/documents
GRIM_EMBEDDING_DIMENSIONS=1536
GRIM_EMBEDDING_BASE_URL=https://api.openai.com/v1
GRIM_EMBEDDING_TOKEN=

# Auth (optional): if GRIM_BEARER is unset, auth is disabled (no token required)
# GRIM_BEARER=your-secret-token

# Paths (optional)
# GRIM_TMP_DIR=/absolute/path/to/tmp
# GRIM_SURREAL_URL=surrealkv:///absolute/path/to/surreal
# GRIM_SURREAL_NAMESPACE=grimoire
# GRIM_SURREAL_DATABASE=main

# Embedding provider
# GRIM_EMBEDDING_MODEL=text-embedding-3-small

# Surreal fulltext analyzers (comma-separated snowball languages)
# GRIM_FULLTEXT_LANGUAGES=english,spanish

# OCR provider (markitdown-ocr via OpenAI-compatible vision API)
# GRIM_OCR_BASE_URL=https://openrouter.ai/api/v1
# GRIM_OCR_TOKEN=sk-or-...
# GRIM_OCR_MODEL=google/gemini-2.5-flash

# Watcher (optional)
# GRIM_WATCH_DEBOUNCE=10

# API docs (optional)
# GRIM_DOCS=0
# GRIM_LOG_LEVEL=INFO
