<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>local.knowledge-rag-proxy</string>
	<key>WorkingDirectory</key>
	<string>/path/to/knowledge-rag-proxy</string>
	<key>ProgramArguments</key>
	<array>
		<string>/path/to/knowledge-rag-proxy/scripts/run-server.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/path/to/knowledge-rag-proxy/logs/stdout.log</string>
	<key>StandardErrorPath</key>
	<string>/path/to/knowledge-rag-proxy/logs/stderr.log</string>
</dict>
</plist>
